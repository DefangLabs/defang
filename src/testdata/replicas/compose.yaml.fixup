autoscaled:
    image: nginx:latest
    networks:
        default: null
    x-defang-autoscaling: true
default:
    image: nginx:latest
    networks:
        default: null
deploy:
    deploy:
        resources:
            reservations:
                cpus: 0.25
                memory: "268435456"
    image: nginx:latest
    networks:
        default: null
managed:
    image: redis:latest
    networks:
        default: null
    ports:
        - mode: host
          target: 6379
          protocol: tcp
    x-defang-redis: true
replicated:
    deploy:
        replicas: 3
    image: nginx:latest
    networks:
        default: null
