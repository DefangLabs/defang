nginx:
    command: null
    deploy:
        placement: {}
        resources:
            reservations:
                memory: "268435456"
    entrypoint: null
    environment:
        dummy: null
    image: nginx
    networks:
        default: null
    ports:
        - app_protocol: http
          mode: ingress
          protocol: tcp
          target: 80
    restart: unless-stopped
