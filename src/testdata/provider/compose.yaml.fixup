{
  "ai_runner": {
    "command": [
      "--drop_params",
      "--model",
      "ai/smollm2"
    ],
    "entrypoint": null,
    "environment": {
      "DEBUG": "true",
      "LITELLM_MASTER_KEY": ""
    },
    "image": "litellm/litellm:v1.82.3-stable.patch.3",
    "networks": {
      "model_provider_private": null
    },
    "ports": [
      {
        "mode": "host",
        "target": 4000,
        "protocol": "tcp"
      }
    ]
  },
  "chat": {
    "command": null,
    "depends_on": {
      "ai_runner": {
        "condition": "service_started",
        "required": true
      }
    },
    "entrypoint": null,
    "environment": {
      "AI_RUNNER_MODEL": "ai/smollm2",
      "AI_RUNNER_URL": "http://mock-ai-runner/api/v1/"
    },
    "image": "my-chat-app",
    "networks": {
      "default": null,
      "model_provider_private": null
    }
  }
}