railpack-long:
    build:
        context: .
        dockerfile: '*Railpack'
    command:
        - exec node index.js
    networks:
        default: null
railpack-short:
    build:
        context: .
        dockerfile: '*Railpack'
    command:
        - npm start
    networks:
        default: null
railpackwithdockerfile:
    build:
        context: .
        dockerfile: '*Railpack'
    command:
        - something "with space" "${PORT}"
    networks:
        default: null
