{
  "ai_model": {
    "command": [
      "--drop_params",
      "--model",
      "ai/model"
    ],
    "entrypoint": null,
    "environment": {
      "LITELLM_MASTER_KEY": ""
    },
    "image": "litellm/litellm:v1.82.3-stable.patch.3",
    "networks": {
      "model_provider_private": null
    },
    "ports": [
      {
        "mode": "host",
        "target": 4000,
        "protocol": "tcp"
      }
    ]
  },
  "modellist": {
    "command": null,
    "entrypoint": null,
    "environment": {
      "AI_MODEL_MODEL": "ai/model",
      "AI_MODEL_URL": "http://mock-ai-model/api/v1/"
    },
    "image": "app",
    "models": {
      "ai_model": null
    },
    "networks": {
      "default": null,
      "model_provider_private": null
    }
  },
  "modelmap": {
    "command": null,
    "entrypoint": null,
    "environment": {
      "AI_MODEL_MODEL": "ai/model",
      "AI_MODEL_URL": "http://mock-ai-model/api/v1/"
    },
    "image": "app",
    "models": {
      "ai_model": null
    },
    "networks": {
      "default": null,
      "model_provider_private": null
    }
  },
  "my_model": {
    "command": [
      "--drop_params",
      "--model",
      "ai/model"
    ],
    "entrypoint": null,
    "environment": {
      "LITELLM_MASTER_KEY": ""
    },
    "image": "litellm/litellm:v1.82.3-stable.patch.3",
    "networks": {
      "model_provider_private": null
    },
    "ports": [
      {
        "mode": "host",
        "target": 4000,
        "protocol": "tcp"
      }
    ]
  },
  "withendpoint": {
    "command": null,
    "entrypoint": null,
    "environment": {
      "MODEL_URL": "http://mock-my-model/api/v1/",
      "MY_MODEL_MODEL": "ai/model"
    },
    "image": "app",
    "models": {
      "my_model": {
        "endpoint_var": "MODEL_URL"
      }
    },
    "networks": {
      "default": null,
      "model_provider_private": null
    }
  }
}