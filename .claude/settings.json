{
  "permissions": {
    "allow": [
      "Bash(cd src && go build:*)",
      "Bash(cd src && go mod tidy:*)",
      "Bash(cd src && go vet:*)",
      "Bash(docker pull:*)",
      "Bash(gh run *)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-remote:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go vet:*)",
      "Bash(head:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(xxd:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '/src/.*\\.go$'; then PKG=$(dirname \"$FILE\" | sed 's|.*/src/||'); cd src && golangci-lint run --fix \"./$PKG/...\" 2>/dev/null || true; fi",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
